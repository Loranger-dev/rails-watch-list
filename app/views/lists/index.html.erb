<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Mes listes</h1>
    <%= link_to "Nouvelle liste", new_list_path, class: "btn btn-primary" %>
  </div>

  <div class="row g-3">
    <% @lists.each do |list| %>
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="card-title"><%= list.name %></h5>
            <p class="text-muted"><%= list.bookmarks.count %> film(s)</p>
            <%= link_to "Voir la liste", list_path(list), class: "btn btn-outline-primary btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
