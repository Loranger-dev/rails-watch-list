<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @list.name %></h1>
    <%= link_to "Ajouter un film", new_list_bookmark_path(@list), class: "btn btn-success" %>
  </div>

  <% if @list.bookmarks.any? %>
    <div class="row g-3">
      <% @list.bookmarks.each do |bookmark| %>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <%= image_tag bookmark.movie.poster_url,
                class: "card-img-top",
                style: "height: 250px; object-fit: cover;" %>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= bookmark.movie.title %></h5>
              <p class="text-muted fst-italic"><%= bookmark.comment %></p>
              <div class="mt-auto">
                <%= link_to "Supprimer",
                    list_bookmark_path(@list, bookmark),
                    data: { turbo_method: :delete, turbo_confirm: "Sûr ?" },
                    class: "btn btn-danger btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">Aucun film dans cette liste. Ajoutes-en un !</p>
  <% end %>

  <div class="mt-4">
    <%= link_to "← Retour aux listes", lists_path, class: "btn btn-outline-secondary" %>
  </div>
</div>
